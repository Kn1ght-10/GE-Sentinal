# REQUIRED for live collection: descriptive User-Agent with contact info.
# The wiki API pre-emptively blocks default client UAs (python-requests etc).
GE_SENTINEL_UA="ge-sentinel collector - your_email@example.com"

# Storage. Default is SQLite at data/ge_sentinel.db; point at Postgres/Timescale
# for production (see db/migrations/001_timescale.sql).
# GE_SENTINEL_DB=postgresql+psycopg://user:pass@localhost:5432/ge_sentinel

# Optional: LLM-polished analyst memos (deterministic template otherwise).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
